# OpenCode + 9Router Configuration
# Copy this file to .env and fill in your values

# OpenCode Web UI
OPENCODE_PORT=3000
OPENCODE_HOST=0.0.0.0

# 9Router Dashboard
ROUTER_PORT=20128

# Provider API Keys (add your keys here)
# Get keys from 9Router dashboard after first run
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
